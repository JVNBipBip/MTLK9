rules_version = '2';
// All Firestore access is via Firebase Admin SDK (Next.js API routes, Firebase Functions).
// The Admin SDK bypasses these rules. These rules apply only to client-side Firebase SDK access.
// Deny all direct client access — no client code should read/write Firestore directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
